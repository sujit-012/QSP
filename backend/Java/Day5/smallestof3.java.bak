class Smallestof3 
{
	public static void main(String[] args) 
	{
		int n1 = 10;
		int n2 = 600;
		int n3 = 20;
		
		int small = (n1 < n2) ? n1 : n2;
		
		int res = (n3 < small) ? n3 : small;
		System.out.println(res);
		
		int res2 = (n1 < ((n2 < n3) ? n2 : n3)) ? n1 : ((n2 < n3) ? n2 : n3);
		System.out.println(res2);
		
		int res3 = (((n1 < n2) ? n1 : n2) < n3 )? ((n1 < n2) ? n1 : n2) : n3;
		System.out.println(res3);
		
		int res4 = (n1 < n2) ? ((n1 < n3) ? n1 : n3) : ((n2 < n3) ? n2 : n3);
		System.out.println(res4);
		
		int small1 = 0
		int res5 = (n1 < (small1 = (n2 < n3) ? n2 : n3) )? n1 : small1;
		System.out.println(res5);
	}
}
